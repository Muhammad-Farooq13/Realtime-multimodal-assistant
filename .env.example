# ─────────────────────────────────────────────────────────────────────────────
# Real-Time Multimodal Assistant — Environment Variables
# Copy this file to .env and fill in the values.
# NEVER commit .env to version control.
# ─────────────────────────────────────────────────────────────────────────────

# ── LLM ──────────────────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-...
LLM_MODEL=gpt-4o-mini
# Override to use local Ollama: http://localhost:11434/v1
LLM_BASE_URL=https://api.openai.com/v1
LLM_MAX_TOKENS=512
LLM_TEMPERATURE=0.7

# ── STT (Speech-to-Text) ─────────────────────────────────────────────────────
# Options: tiny, base, small, medium, large-v2, large-v3
WHISPER_MODEL_SIZE=base
# Options: cpu, cuda, auto
WHISPER_DEVICE=cpu
WHISPER_COMPUTE_TYPE=int8
# Fallback model when STT budget is exceeded
WHISPER_FALLBACK_MODEL_SIZE=tiny

# ── TTS (Text-to-Speech) ─────────────────────────────────────────────────────
TTS_VOICE=en-US-AriaNeural
TTS_RATE=+0%
TTS_VOLUME=+0%

# ── Latency Budgets (milliseconds) ───────────────────────────────────────────
PIPELINE_TOTAL_BUDGET_MS=2000
STT_TIMEOUT_MS=600
LLM_TIMEOUT_MS=1200
TTS_TIMEOUT_MS=400
VISION_TIMEOUT_MS=150

# ── Circuit Breaker ───────────────────────────────────────────────────────────
CIRCUIT_BREAKER_FAILURE_THRESHOLD=5
CIRCUIT_BREAKER_SUCCESS_THRESHOLD=2
CIRCUIT_BREAKER_RECOVERY_SECONDS=30

# ── API ───────────────────────────────────────────────────────────────────────
API_HOST=0.0.0.0
API_PORT=8000
API_WORKERS=1
CORS_ORIGINS=["http://localhost:3000","http://localhost:8080"]

# ── Monitoring ────────────────────────────────────────────────────────────────
METRICS_ENABLED=true
TRACING_ENABLED=false
OTLP_ENDPOINT=http://localhost:4317
LOG_LEVEL=INFO
LOG_FORMAT=json

# ── Audio ─────────────────────────────────────────────────────────────────────
AUDIO_SAMPLE_RATE=16000
AUDIO_CHUNK_DURATION_MS=30
VAD_AGGRESSIVENESS=2           # 0=least aggressive, 3=most aggressive
MAX_AUDIO_DURATION_SECONDS=30
